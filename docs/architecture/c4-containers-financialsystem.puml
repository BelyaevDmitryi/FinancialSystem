@startuml c4-containers-financialsystem
' Модули из корневого pom.xml: EurekaServer, ApiGateway, BrokerIntegrationService, PriceService, UserService, AnalyticsService, TradingTerminalService, TradingBotService, AdminPanelService, DashboardService.
' Маршруты Gateway: application.yml ApiGateway — lb://*-service; discovery locator lower-case-service-id.
' Принципы: граница bounded context = граница сервиса; межсервисная оркестрация — OpenFeign поверх Eureka (lb://); fs-trading-core (план) — jar без Spring Cloud; будущие BacktestService / Optimizer — см. OS_ENGINE_TRANSFORMATION_ALGORITHM.md.

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_TOP_DOWN()

title C4 — контейнеры: FinancialSystem (Spring Cloud, несколько JAR)

Person(trader, "Пользователь / трейдер", "REST-клиент.")
Person(admin, "Администратор", "Админ-панель и дашборд.")

System_Boundary(fs, "FinancialSystem") {

    Container(eureka, "Eureka Server", "Spring Cloud Netflix Eureka", "Service discovery; единый реестр экземпляров микросервисов.")
    Container(gateway, "API Gateway", "Spring Cloud Gateway", "Порт 8090; маршруты /api/auth, /api/users, /api/price-service, /api/broker, /api/analytics, /api/orders, /api/bots, /api/admin, /api/dashboard; балансировка lb://…")

    Container(user, "User Service", "Spring Boot, JPA", "Аутентификация, пользователи, портфель, профиль.")
    Container(price, "Price Service", "Spring Boot", "Актуальные цены / кеширование (ориентир Redis в документации).")
    Container(broker, "Broker Integration Service", "Spring Boot, WebClient", "Адаптеры брокеров (TinkoffBrokerAdapter и др.).")
    Container(analytics, "Analytics Service", "Spring Boot", "Индикаторы: SMA, EMA, MACD, волатильность.")
    Container(terminal, "Trading Terminal Service", "Spring Boot", "Ордера и торговый контур.")
    Container(bot, "Trading Bot Service", "Spring Boot, Scheduler", "Роботы и стратегии; тики по расписанию.")
    Container(admin_panel, "Admin Panel Service", "Spring Boot", "Агрегированная админ-статистика (Feign к другим сервисам).")
    Container(dashboard, "Dashboard Service", "Spring Boot", "Данные для дашборда.")

    ContainerDb(pg, "PostgreSQL", "PostgreSQL 15", "БД сервисов (отдельные схемы/БД по docker/init; не один процесс приложения).")
}

System_Ext(broker_api, "API брокера", "Т-Инвестиции и др.")

' Планируемая зависимость Maven — не отдельный runtime-контейнер в docker-compose.
note as NCore
  **План (не в pom сейчас):** артефакт **fs-trading-core** — общие доменные типы (свеча, интервал, FIGI, сторона сделки), без Spring Cloud / Feign.
  **Будущее (фазы C–D):** BacktestService, Optimizer — отдельные деплои или модули по docs/OS_ENGINE_TRANSFORMATION_ALGORITHM.md.
end note

Rel(trader, gateway, "HTTPS", "JSON, JWT")
Rel(admin, gateway, "HTTPS", "JSON, JWT")

Rel(gateway, user, "Маршрутизация", "HTTP lb://user-service")
Rel(gateway, price, "Маршрутизация", "HTTP lb://price-service")
Rel(gateway, broker, "Маршрутизация", "HTTP lb://broker-integration-service")
Rel(gateway, analytics, "Маршрутизация", "HTTP lb://analytics-service")
Rel(gateway, terminal, "Маршрутизация", "HTTP lb://trading-terminal-service")
Rel(gateway, bot, "Маршрутизация", "HTTP lb://trading-bot-service")
Rel(gateway, admin_panel, "Маршрутизация", "HTTP lb://admin-panel-service")
Rel(gateway, dashboard, "Маршрутизация", "HTTP lb://dashboard-service")

Rel(user, eureka, "Регистрация / discovery", "HTTP")
Rel(price, eureka, "Регистрация / discovery", "HTTP")
Rel(broker, eureka, "Регистрация / discovery", "HTTP")
Rel(analytics, eureka, "Регистрация / discovery", "HTTP")
Rel(terminal, eureka, "Регистрация / discovery", "HTTP")
Rel(bot, eureka, "Регистрация / discovery", "HTTP")
Rel(admin_panel, eureka, "Регистрация / discovery", "HTTP")
Rel(dashboard, eureka, "Регистрация / discovery", "HTTP")
Rel(gateway, eureka, "Получение инстансов", "HTTP")

Rel(broker, broker_api, "Котировки, заявки", "HTTPS")

Rel(user, pg, "JDBC", "SQL")
Rel(terminal, pg, "JDBC", "SQL")
Rel(bot, pg, "JDBC", "SQL")
Rel_R(admin_panel, user, "Feign", "HTTP JSON")
Rel_R(admin_panel, bot, "Feign", "HTTP JSON")
Rel_R(admin_panel, terminal, "Feign", "HTTP JSON")

Rel_R(dashboard, user, "Feign", "HTTP JSON")
Rel_R(dashboard, price, "Feign", "HTTP JSON")
Rel_R(dashboard, bot, "Feign", "HTTP JSON")
Rel_R(dashboard, terminal, "Feign", "HTTP JSON")

Rel_R(bot, analytics, "Feign", "HTTP JSON")
Rel_R(bot, price, "Feign", "HTTP JSON")
Rel_R(bot, terminal, "Feign", "HTTP JSON")

Rel_R(user, price, "Feign", "HTTP JSON")
Rel_R(user, broker, "Feign", "HTTP JSON")

Rel_R(terminal, broker, "Feign", "HTTP JSON")
Rel_R(terminal, user, "Feign", "HTTP JSON")

Rel_R(price, broker, "Feign", "HTTP JSON")

Rel_R(analytics, price, "Feign", "HTTP JSON")

note bottom of fs
  **Не один deployable:** каждый контейнер — отдельный Spring Boot-приложение со своим жизненным циклом и масштабированием.
  OsEngine: типично один пользовательский ПК и связка десктоп-процессов; FS — **сетевая декомпозиция** и **шлюз** как единая внешняя граница.
end note

SHOW_LEGEND()

@enduml
